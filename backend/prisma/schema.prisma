generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id // Firebase UID
  email            String
  username         String?         @unique
  avatarUrl        String?
  createdAt        DateTime        @default(now())
  folders          Folder[]
  pages            Page[]
  flashcardFolders FlashcardFolder[]
  decks            Deck[]
  flashCards       FlashCard[]
  reviews          Review[]
  studySettings    StudySettings?
  sentInvites      NoteInvite[]    @relation("SentInvites")
  receivedInvites  NoteInvite[]    @relation("ReceivedInvites")
}

model Folder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String   @default("blue")
  order     Int      @default(0)
  collapsed Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages     Page[]

  @@index([userId])
}

model Page {
  id                String    @id @default(uuid())
  userId            String
  folderId          String
  title             String
  content           String    @db.LongText
  order             Int       @default(0)
  isPublic          Boolean   @default(false)
  publicDescription String?   @db.Text
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder            Folder      @relation(fields: [folderId], references: [id], onDelete: Cascade)
  invites           NoteInvite[]

  @@index([userId])
  @@index([folderId])
}

model FlashcardFolder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String   @default("blue")
  collapsed Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  decks     Deck[]

  @@index([userId])
}

model Deck {
  id                String          @id @default(uuid())
  userId            String
  folderId          String
  name              String
  order             Int             @default(0)
  isPublic          Boolean         @default(false)
  publicDescription String?         @db.Text
  publishedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder            FlashcardFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  cards             FlashCard[]
  reviews           Review[]

  @@index([userId])
  @@index([folderId])
}

model FlashCard {
  id             String    @id @default(uuid())
  userId         String
  deckId         String
  type           String    @default("rate")
  question       String    @db.Text
  answer         String    @db.Text
  order          Int       @default(0)
  state          String    @default("new")
  due            BigInt?
  intervalSec    BigInt    @default(0)
  ease           Int       @default(2500)
  reps           Int       @default(0)
  lapses         Int       @default(0)
  learningStep   Int       @default(0)
  lastReviewedAt BigInt?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck           Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews        Review[]

  @@index([userId])
  @@index([deckId])
}

model Review {
  id              String    @id @default(uuid())
  userId          String
  cardId          String
  deckId          String
  reviewedAt      BigInt
  grade           Int
  prevState       String
  newState        String
  prevIntervalSec BigInt
  newIntervalSec  BigInt
  prevEase        Int
  newEase         Int
  prevDue         BigInt?
  newDue          BigInt
  elapsedMs       Int?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card            FlashCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  deck            Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([cardId])
  @@index([deckId])
}

model StudySettings {
  id                       String @id @default(uuid())
  userId                   String @unique
  newCardsPerDay           Int    @default(20)
  maxReviewsPerDay         Int    @default(200)
  learningStepsSec         Json   @default("[60,600]")
  relearningStepsSec       Json   @default("[600]")
  graduatingIntervalDays   Int    @default(1)
  easyIntervalDays         Int    @default(4)
  startingEase             Int    @default(2500)
  easyBonusPermille        Int    @default(1300)
  hardMultiplierPermille   Int    @default(1200)
  intervalModifierPermille Int    @default(1000)
  maxIntervalDays          Int    @default(36500)
  newDayStartsAtHour       Int    @default(4)
  user                     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NoteInvite {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  pageId      String
  status      String   @default("pending") // pending, accepted, declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sender      User     @relation("SentInvites", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("ReceivedInvites", fields: [recipientId], references: [id], onDelete: Cascade)
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([recipientId, pageId])
  @@index([senderId])
  @@index([recipientId])
  @@index([pageId])
}
