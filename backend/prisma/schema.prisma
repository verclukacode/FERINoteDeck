generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id // Firebase UID
  email     String
  username  String?  @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  folders          Folder[]
  pages            Page[]
  flashcardFolders FlashcardFolder[]
  decks            Deck[]
  flashCards       FlashCard[]
  reviews          Review[]
  studySettings    StudySettings?
}

model Folder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String   @default("blue")
  order     Int      @default(0)
  collapsed Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages     Page[]

  @@index([userId])
}

model Page {
  id        String   @id @default(uuid())
  userId    String
  folderId  String
  title     String
  content   String   @db.LongText
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Marketplace sharing (see frontend/docs/marketplace if added).
  isPublic          Boolean   @default(false)
  publicDescription String?   @db.Text
  publishedAt       DateTime? // set/cleared on isPublic transitions; drives recency sort

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([folderId])
  @@index([isPublic, publishedAt])
}

model FlashcardFolder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String   @default("blue")
  collapsed Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  decks     Deck[]

  @@index([userId])
}

model Deck {
  id        String   @id @default(uuid())
  userId    String
  folderId  String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Marketplace sharing.
  isPublic          Boolean   @default(false)
  publicDescription String?   @db.Text
  publishedAt       DateTime?

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder FlashcardFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  cards  FlashCard[]

  @@index([userId])
  @@index([folderId])
  @@index([isPublic, publishedAt])
}

model FlashCard {
  id        String   @id @default(uuid())
  userId    String
  deckId    String
  type      String   @default("rate")
  question  String   @db.Text
  answer    String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // SM-2 spaced-repetition scheduling. All timestamps are unix ms (BigInt);
  // durations are seconds. See backend/src/lib/srs.ts.
  state          String  @default("new") // new | learning | review | relearning
  due            BigInt? // unix ms; null for new cards (queue orders new by `order`)
  intervalSec    BigInt  @default(0) // current interval, seconds
  ease           Int     @default(2500) // permille, floor 1300
  reps           Int     @default(0)
  lapses         Int     @default(0)
  learningStep   Int     @default(0)
  lastReviewedAt BigInt? // unix ms

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck    Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([userId])
  @@index([deckId])
  @@index([deckId, due])
}

// One row per answer (revlog). Timestamps unix ms; durations seconds.
model Review {
  id              String   @id @default(uuid())
  userId          String
  cardId          String
  deckId          String
  reviewedAt      BigInt // unix ms
  grade           Int // 1=Again 2=Hard 3=Good 4=Easy
  prevState       String
  newState        String
  prevIntervalSec BigInt
  newIntervalSec  BigInt
  prevEase        Int
  newEase         Int
  prevDue         BigInt?
  newDue          BigInt
  elapsedMs       Int?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card            FlashCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, reviewedAt])
  @@index([deckId, reviewedAt])
  @@index([cardId])
}

// Per-user, profile-wide study defaults (no per-deck overrides).
model StudySettings {
  id                       String @id @default(uuid())
  userId                   String @unique
  newCardsPerDay           Int    @default(20)
  maxReviewsPerDay         Int    @default(200)
  learningStepsSec         Json   @default("[60, 600]")
  relearningStepsSec       Json   @default("[600]")
  graduatingIntervalDays   Int    @default(1)
  easyIntervalDays         Int    @default(4)
  startingEase             Int    @default(2500)
  easyBonusPermille        Int    @default(1300)
  hardMultiplierPermille   Int    @default(1200)
  intervalModifierPermille Int    @default(1000)
  maxIntervalDays          Int    @default(36500)
  newDayStartsAtHour       Int    @default(4)
  user                     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
