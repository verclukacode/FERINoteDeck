PORT=3001

# MySQL — see backend/docs/SETUP.md
DATABASE_URL="mysql://notedeck:notedeck@localhost:3306/notedeck"

# Firebase service account — see backend/docs/SETUP.md
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:5173

# AI Import — OpenAI key (server-only). User access is gated by User.tier
# in the database (basic = blocked, pro|premium = allowed). If OPENAI_API_KEY
# is unset, /api/import returns 503 (feature disabled).
OPENAI_API_KEY=
